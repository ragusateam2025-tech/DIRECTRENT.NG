# ================================================
# DIRECTRENT.NG WEBSITE - ENVIRONMENT VARIABLES
# ================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ================================================

# ------------------------------------------------
# SITE CONFIGURATION
# ------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://directrent.ng
NEXT_PUBLIC_SITE_NAME=Directrent.ng
NEXT_PUBLIC_SITE_DESCRIPTION=Connect directly with landlords and tenants in Lagos. No middlemen, no stress.

# ------------------------------------------------
# EMAIL SERVICE (Resend)
# ------------------------------------------------
# Get your API key from: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email addresses for notifications
CONTACT_EMAIL=hello@directrent.ng
NOTIFICATION_EMAIL=notifications@directrent.ng

# ------------------------------------------------
# NEWSLETTER SERVICE (Mailchimp)
# ------------------------------------------------
# Get from Mailchimp account settings
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us1
# Data center (the part after the dash in your API key)
MAILCHIMP_DC=us1
# Get from Mailchimp audience settings
MAILCHIMP_AUDIENCE_ID=xxxxxxxxxxxx

# ------------------------------------------------
# RATE LIMITING (Upstash Redis)
# ------------------------------------------------
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------
# ANALYTICS
# ------------------------------------------------
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ------------------------------------------------
# ERROR TRACKING (Optional - Sentry)
# ------------------------------------------------
# SENTRY_DSN=https://xxxxxx@sentry.io/xxxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxx@sentry.io/xxxxxx
# SENTRY_ORG=directrent
# SENTRY_PROJECT=website

# ------------------------------------------------
# DEPLOYMENT (Vercel - Auto-populated)
# ------------------------------------------------
# These are automatically set by Vercel
# VERCEL_URL=
# VERCEL_ENV=
# VERCEL_GIT_COMMIT_SHA=
# VERCEL_GIT_COMMIT_MESSAGE=
# VERCEL_GIT_COMMIT_AUTHOR_NAME=

# ------------------------------------------------
# DEVELOPMENT ONLY
# ------------------------------------------------
# Set to 'true' to enable bundle analyzer
# ANALYZE=false
